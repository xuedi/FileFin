# Go build output
/bin/
*.test
*.out
*.prof

# Go workspace (local only)
go.work
go.work.sum

# Frontend build artifacts (regenerated by `just web-build`). Keep the dist
# directory present via .gitkeep so the Go embed always compiles.
/web/node_modules/
/web/dist/*
!/web/dist/.gitkeep

# Local runtime media (the filesystem is the source of truth). Keep the empty
# directory tracked so it exists on a fresh clone.
/data/*
!/data/.gitkeep

# Disposable cache index
*.sqlite
*.sqlite-*
*.db

# IDEs / editors
/.idea/
*.iml
*.swp
*~
.vscode/

# OS noise
.DS_Store
Thumbs.db
