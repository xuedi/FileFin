# Go build output
/bin/
*.test
*.out

# Frontend build artifacts (regenerated by `just web-build`). Keep the dist
# directory present via .gitkeep so the Go embed always compiles.
/web/node_modules/
/web/dist/*
!/web/dist/.gitkeep

# Local runtime data and cache (filesystem is the source of truth)
/data/
*.sqlite
*.sqlite-*
*.db

# Editor / OS noise
/.idea/
.DS_Store
